rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Client accounts
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // Public directory (sync/import from your admin tooling or a separate pipeline)
    match /photographers/{id} {
      allow read: if true;
      allow write: if false;
    }

    // Logged-in clients create booking requests (userId must match auth)
    match /photographerBookings/{id} {
      allow read: if false;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.photographerId is string
        && request.resource.data.photographerId.size() > 0
        && request.resource.data.photographerId.size() < 220
        && request.resource.data.photographerName is string
        && request.resource.data.photographerName.size() > 0
        && request.resource.data.photographerName.size() < 220
        && request.resource.data.userName is string
        && request.resource.data.userName.size() > 0
        && request.resource.data.userName.size() < 220
        && request.resource.data.userEmail is string
        && request.resource.data.userEmail.size() > 2
        && request.resource.data.userEmail.size() < 320
        && request.resource.data.eventType is string
        && request.resource.data.eventType.size() > 0
        && request.resource.data.eventType.size() < 120
        && request.resource.data.eventLocation is string
        && request.resource.data.eventLocation.size() > 0
        && request.resource.data.eventLocation.size() < 500
        && request.resource.data.duration is string
        && request.resource.data.duration.size() > 0
        && request.resource.data.duration.size() < 120
        && request.resource.data.eventDate is string
        && request.resource.data.eventDate.size() > 0
        && request.resource.data.eventDate.size() < 80
        && request.resource.data.notes is string
        && request.resource.data.notes.size() < 8000
        && (!request.resource.data.keys().hasAny(['promoNote'])
            || (request.resource.data.promoNote is string
                && request.resource.data.promoNote.size() < 500));
      allow update, delete: if false;
    }

    // Newsletter (optional landing form — tighten or add rate limits in production)
    match /fotomaticNewsletterLeads/{id} {
      allow read: if false;
      allow create: if request.resource.data.email is string &&
                      request.resource.data.email.size() > 3 &&
                      request.resource.data.source == 'fotomatic';
      allow update, delete: if false;
    }

    match /photographerApplications/{id} {
      allow read: if false;
      allow create: if request.resource.data.source == 'fotomatic' &&
                      request.resource.data.name is string &&
                      request.resource.data.name.size() > 0 &&
                      request.resource.data.email is string &&
                      request.resource.data.email.size() > 3 &&
                      request.resource.data.city is string &&
                      request.resource.data.country is string &&
                      request.resource.data.interestedInClientWork is bool;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
